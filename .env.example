# OpenClaw Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# LLM Provider Selection
# ============================================
# The OpenClaw configuration supports multiple LLM providers.
# To switch between providers, update the 'model' field in config/openclaw.json:
#
# Option 1 - Ollama (Local):
#   "model": "ollama/minimax-m2.7:cloud"
#
# Option 2 - OpenRouter (Cloud - Free Models):
#   "model": "openrouter/google/gemini-2.0-flash-exp:free"
#   "model": "openrouter/google/gemini-2.5-pro-exp-03-25:free"
#   "model": "openrouter/deepseek/deepseek-chat:free"
#
# The agent configuration in config/openclaw.json includes examples for both:
# - qa-senior: Uses Ollama (local)
# - qa-senior-openrouter: Uses OpenRouter (cloud)

# ============================================
# API Keys
# ============================================

# OpenRouter API Key (required if using OpenRouter provider)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Note: Ollama doesn't require an API key for local usage
# It runs on http://ollama:11434 inside the Docker network

# ============================================
# Optional Configuration
# ============================================

# OpenClaw Gateway Token (for WebSocket/API authentication)
# OPENCLAW_GATEWAY_TOKEN=your_custom_token

# Ollama Base URL (usually doesn't need to be changed in Docker setup)
# OLLAMA_BASE_URL=http://ollama:11434
